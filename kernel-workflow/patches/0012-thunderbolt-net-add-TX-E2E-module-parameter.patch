From 46e1802f6d87c2edc8f30d4d3b7faa6fbc1efa6c Mon Sep 17 00:00:00 2001
From: georgewhewell <georgerw@gmail.com>
Date: Sun, 7 Jun 2026 00:19:57 +0200
Subject: [PATCH] thunderbolt: net: add TX E2E module parameter

---
 drivers/net/thunderbolt/main.c | 22 ++++++++++++++++------
 1 file changed, 16 insertions(+), 6 deletions(-)

diff --git a/drivers/net/thunderbolt/main.c b/drivers/net/thunderbolt/main.c
index f8f97e8e2226..a200964091f2 100644
--- a/drivers/net/thunderbolt/main.c
+++ b/drivers/net/thunderbolt/main.c
@@ -219,6 +219,11 @@ static bool tbnet_e2e = true;
 module_param_named(e2e, tbnet_e2e, bool, 0444);
 MODULE_PARM_DESC(e2e, "USB4NET full end-to-end flow control (default: true)");
 
+static bool tbnet_tx_e2e = true;
+module_param_named(tx_e2e, tbnet_tx_e2e, bool, 0444);
+MODULE_PARM_DESC(tx_e2e,
+		 "USB4NET TX ring end-to-end flow control when E2E is negotiated (default: true)");
+
 static void tbnet_fill_header(struct thunderbolt_ip_header *hdr, u64 route,
 	u8 sequence, const uuid_t *initiator_uuid, const uuid_t *target_uuid,
 	enum thunderbolt_ip_type type, size_t size, u32 command_id)
@@ -916,17 +921,22 @@ static int tbnet_open(struct net_device *dev)
 	struct tb_xdomain *xd = net->xd;
 	u16 sof_mask, eof_mask;
 	struct tb_ring *ring;
-	unsigned int flags;
+	unsigned int rx_flags, tx_flags;
 	int hopid;
 
 	netif_carrier_off(dev);
 
-	flags = RING_FLAG_FRAME;
+	rx_flags = RING_FLAG_FRAME;
+	tx_flags = RING_FLAG_FRAME;
+
 	/* Only enable full E2E if the other end supports it too */
-	if (tbnet_e2e && net->svc->prtcstns & TBNET_E2E)
-		flags |= RING_FLAG_E2E;
+	if (tbnet_e2e && net->svc->prtcstns & TBNET_E2E) {
+		rx_flags |= RING_FLAG_E2E;
+		if (tbnet_tx_e2e)
+			tx_flags |= RING_FLAG_E2E;
+	}
 
-	ring = tb_ring_alloc_tx(xd->tb->nhi, -1, TBNET_RING_SIZE, flags);
+	ring = tb_ring_alloc_tx(xd->tb->nhi, -1, TBNET_RING_SIZE, tx_flags);
 	if (!ring) {
 		netdev_err(dev, "failed to allocate Tx ring\n");
 		return -ENOMEM;
@@ -945,7 +955,7 @@ static int tbnet_open(struct net_device *dev)
 	sof_mask = BIT(TBIP_PDF_FRAME_START);
 	eof_mask = BIT(TBIP_PDF_FRAME_END);
 
-	ring = tb_ring_alloc_rx(xd->tb->nhi, -1, TBNET_RING_SIZE, flags,
+	ring = tb_ring_alloc_rx(xd->tb->nhi, -1, TBNET_RING_SIZE, rx_flags,
 				net->tx_ring.ring->hop, sof_mask,
 				eof_mask, tbnet_start_poll, net);
 	if (!ring) {
-- 
2.54.0

