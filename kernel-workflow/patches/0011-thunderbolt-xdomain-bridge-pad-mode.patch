From b4e4fc3b334d6207f81e5fccae3572dee066e99c Mon Sep 17 00:00:00 2001
From: georgewhewell <georgerw@gmail.com>
Date: Sat, 6 Jun 2026 17:57:01 +0200
Subject: [PATCH] thunderbolt: add XDomain bridge padding mode

---
 drivers/thunderbolt/xdomain.c | 945 +++++++++++++++++++++++++++-------
 1 file changed, 746 insertions(+), 199 deletions(-)

diff --git a/drivers/thunderbolt/xdomain.c b/drivers/thunderbolt/xdomain.c
index cc2bb5ffd9ee..c0be863daefa 100644
--- a/drivers/thunderbolt/xdomain.c
+++ b/drivers/thunderbolt/xdomain.c
@@ -22,6 +22,7 @@
 
 #define XDOMAIN_SHORT_TIMEOUT			100	/* ms */
 #define XDOMAIN_DEFAULT_TIMEOUT			1000	/* ms */
+#define XDOMAIN_BRIDGE_PROPERTIES_TIMEOUT	5000	/* ms */
 #define XDOMAIN_BONDING_TIMEOUT			10000	/* ms */
 #define XDOMAIN_RETRIES				10
 #define XDOMAIN_DEFAULT_MAX_HOPID		15
@@ -68,6 +69,23 @@ module_param_named(xdomain_debug, xdomain_debug, bool, 0644);
 MODULE_PARM_DESC(xdomain_debug,
 		 "log XDomain discovery packets and route matching decisions");
 
+static bool xdomain_bridge_pad;
+module_param_named(xdomain_bridge_pad, xdomain_bridge_pad, bool, 0644);
+MODULE_PARM_DESC(xdomain_bridge_pad,
+		 "pad XDomain packets at routed-hub clobber windows (default: false)");
+
+static unsigned int xdomain_bridge_properties_chunk = 4;
+module_param_named(xdomain_bridge_properties_chunk,
+		   xdomain_bridge_properties_chunk, uint, 0644);
+MODULE_PARM_DESC(xdomain_bridge_properties_chunk,
+		 "maximum properties data dwords per response with bridge padding, or 0 for frame maximum (default: 4)");
+
+static unsigned int xdomain_bridge_properties_retries = 8;
+module_param_named(xdomain_bridge_properties_retries,
+		   xdomain_bridge_properties_retries, uint, 0644);
+MODULE_PARM_DESC(xdomain_bridge_properties_retries,
+		 "properties chunk attempts with bridge padding (default: 8)");
+
 /*
  * Serializes access to the properties and protocol handlers below. If
  * you need to take both this lock and the struct tb_xdomain lock, take
@@ -87,21 +105,45 @@ static const uuid_t tb_xdp_uuid =
 	UUID_INIT(0xb638d70e, 0x42ff, 0x40bb,
 		  0x97, 0xc2, 0x90, 0xe2, 0xc0, 0xb2, 0xff, 0x07);
 
+struct tb_xdomain_protocol_header {
+	struct tb_xdomain_header xd_hdr;
+	uuid_t uuid;
+};
+
+#define XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS	8
+#define XDOMAIN_BRIDGE_PAD_DWORDS		4
+#define XDOMAIN_BRIDGE_PAD_BYTES		(XDOMAIN_BRIDGE_PAD_DWORDS * 4)
+#define XDOMAIN_BRIDGE_DATA_DWORDS		4
+
+static u64 tb_xdomain_route(const struct tb_xdomain_header *hdr)
+{
+	return ((u64)(hdr->route_hi & ~BIT(31)) << 32) | hdr->route_lo;
+}
+
+static u8 tb_xdomain_sequence(const struct tb_xdomain_header *hdr)
+{
+	return (hdr->length_sn & TB_XDOMAIN_SN_MASK) >>
+		TB_XDOMAIN_SN_SHIFT;
+}
+
+static u16 tb_xdomain_length(const struct tb_xdomain_header *hdr)
+{
+	return hdr->length_sn & TB_XDOMAIN_LENGTH_MASK;
+}
+
 static u64 tb_xdp_route(const struct tb_xdp_header *hdr)
 {
-	return ((u64)(hdr->xd_hdr.route_hi & ~BIT(31)) << 32) |
-	       hdr->xd_hdr.route_lo;
+	return tb_xdomain_route(&hdr->xd_hdr);
 }
 
 static u8 tb_xdp_sequence(const struct tb_xdp_header *hdr)
 {
-	return (hdr->xd_hdr.length_sn & TB_XDOMAIN_SN_MASK) >>
-		TB_XDOMAIN_SN_SHIFT;
+	return tb_xdomain_sequence(&hdr->xd_hdr);
 }
 
 static u16 tb_xdp_length(const struct tb_xdp_header *hdr)
 {
-	return hdr->xd_hdr.length_sn & TB_XDOMAIN_LENGTH_MASK;
+	return tb_xdomain_length(&hdr->xd_hdr);
 }
 
 static const char *tb_xdp_type_name(enum tb_xdp_type type)
@@ -136,6 +178,336 @@ static const char *tb_xdp_type_name(enum tb_xdp_type type)
 	}
 }
 
+static void tb_xdomain_set_length(struct tb_xdp_header *hdr, u32 length)
+{
+	hdr->xd_hdr.length_sn &= ~TB_XDOMAIN_LENGTH_MASK;
+	hdr->xd_hdr.length_sn |= length & TB_XDOMAIN_LENGTH_MASK;
+}
+
+static void tb_xdomain_set_sequence(struct tb_xdp_header *hdr, u8 sequence)
+{
+	hdr->xd_hdr.length_sn &= ~TB_XDOMAIN_SN_MASK;
+	hdr->xd_hdr.length_sn |=
+		(sequence << TB_XDOMAIN_SN_SHIFT) & TB_XDOMAIN_SN_MASK;
+}
+
+static enum tb_xdp_type tb_xdp_expected_response_type(enum tb_xdp_type type)
+{
+	switch (type) {
+	case UUID_REQUEST_OLD:
+	case UUID_REQUEST:
+		return UUID_RESPONSE;
+	case PROPERTIES_REQUEST:
+		return PROPERTIES_RESPONSE;
+	case PROPERTIES_CHANGED_REQUEST:
+		return PROPERTIES_CHANGED_RESPONSE;
+	case LINK_STATE_STATUS_REQUEST:
+		return LINK_STATE_STATUS_RESPONSE;
+	case LINK_STATE_CHANGE_REQUEST:
+		return LINK_STATE_CHANGE_RESPONSE;
+	default:
+		return 0;
+	}
+}
+
+static u32 tb_xdomain_bridge_pad_dwords(u32 dwords)
+{
+	if (dwords <= XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS)
+		return 0;
+
+	return XDOMAIN_BRIDGE_PAD_DWORDS *
+		DIV_ROUND_UP(dwords - XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS,
+			     XDOMAIN_BRIDGE_DATA_DWORDS);
+}
+
+static bool tb_xdomain_bridge_pad_marker(const u32 *w, u32 dwords, u32 offset)
+{
+	if (offset + XDOMAIN_BRIDGE_PAD_DWORDS > dwords)
+		return false;
+
+	/*
+	 * The routed-hub path overwrites each vulnerable window with a
+	 * route/length-like marker. Locally padded packets use the same
+	 * shape, so clean and clobbered directions can share the receive path.
+	 */
+	return !(w[offset] & BIT(31)) && w[offset + 2] == w[2] &&
+		w[offset + 3] == ~0U;
+}
+
+static bool tb_xdomain_bridge_pad_present(const void *buf, size_t size)
+{
+	const u32 *w = buf;
+	u32 dwords, length;
+
+	if (!xdomain_bridge_pad || size % 4)
+		return false;
+
+	dwords = size / 4;
+	if (dwords < XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS +
+		     XDOMAIN_BRIDGE_PAD_DWORDS)
+		return false;
+
+	length = w[2] & TB_XDOMAIN_LENGTH_MASK;
+	if (length != dwords - sizeof(struct tb_xdomain_header) / 4)
+		return false;
+
+	return tb_xdomain_bridge_pad_marker(w, dwords,
+					    XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS);
+}
+
+static size_t tb_xdomain_bridge_unpad_copy(void *dst, size_t dst_size,
+					   const void *src, size_t src_size)
+{
+	const u32 *s = src;
+	u32 *d = dst;
+	u32 src_dwords = src_size / 4;
+	u32 dst_dwords = dst_size / 4;
+	u32 src_pos, dst_pos, n, pad_dwords = 0;
+	u32 unpadded_dwords;
+	size_t copy;
+
+	if (!tb_xdomain_bridge_pad_present(src, src_size)) {
+		copy = min(dst_size, src_size);
+		memcpy(dst, src, copy);
+		return copy;
+	}
+
+	n = min_t(u32, XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS, src_dwords);
+	copy = min_t(size_t, n * 4, dst_size);
+	memcpy(d, s, copy);
+	src_pos = n;
+	dst_pos = copy / 4;
+
+	while (src_pos < src_dwords) {
+		if (tb_xdomain_bridge_pad_marker(s, src_dwords, src_pos)) {
+			src_pos += XDOMAIN_BRIDGE_PAD_DWORDS;
+			pad_dwords += XDOMAIN_BRIDGE_PAD_DWORDS;
+		}
+
+		n = min_t(u32, XDOMAIN_BRIDGE_DATA_DWORDS,
+			  src_dwords - src_pos);
+		if (dst_pos < dst_dwords) {
+			copy = min_t(u32, n, dst_dwords - dst_pos);
+			memcpy(d + dst_pos, s + src_pos, copy * 4);
+			dst_pos += copy;
+		}
+		src_pos += n;
+	}
+
+	unpadded_dwords = src_dwords - pad_dwords;
+	if (dst_size >= sizeof(struct tb_xdomain_header))
+		tb_xdomain_set_length(dst, unpadded_dwords -
+				      sizeof(struct tb_xdomain_header) / 4);
+
+	return min_t(size_t, dst_size, unpadded_dwords * 4);
+}
+
+static bool tb_xdomain_match_properties(const struct tb_cfg_request *req,
+					const struct ctl_pkg *pkg)
+{
+	struct tb_xdp_properties_response res = {};
+	struct tb_xdp_properties prop_req = {};
+	size_t req_size, res_size;
+
+	if (!xdomain_bridge_pad)
+		return true;
+
+	if (((const struct tb_xdp_header *)pkg->buffer)->type == ERROR_RESPONSE) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop bridged properties error response route=%llx req_seq=%u frame_size=%u\n",
+					    tb_xdp_route(req->request),
+					    tb_xdp_sequence(req->request),
+					    pkg->frame.size);
+		return false;
+	}
+
+	req_size = tb_xdomain_bridge_unpad_copy(&prop_req, sizeof(prop_req),
+					       req->request,
+					       req->request_size);
+	res_size = tb_xdomain_bridge_unpad_copy(&res, sizeof(res),
+					       pkg->buffer,
+					       pkg->frame.size);
+	if (req_size < sizeof(prop_req))
+		return false;
+
+	if (res_size < sizeof(res)) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop short bridged properties route=%llx req_seq=%u res_size=%zu frame_size=%u\n",
+					    tb_xdp_route(&prop_req.hdr),
+					    tb_xdp_sequence(&prop_req.hdr),
+					    res_size, pkg->frame.size);
+		return false;
+	}
+
+	if (!uuid_equal(&res.src_uuid, &prop_req.dst_uuid) ||
+	    !uuid_equal(&res.dst_uuid, &prop_req.src_uuid)) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop properties uuid route=%llx req_seq=%u res_seq=%u req_src=%pUb req_dst=%pUb res_src=%pUb res_dst=%pUb offset=%u data_len=%u frame_size=%u\n",
+					    tb_xdp_route(&prop_req.hdr),
+					    tb_xdp_sequence(&prop_req.hdr),
+					    tb_xdp_sequence(&res.hdr),
+					    &prop_req.src_uuid,
+					    &prop_req.dst_uuid, &res.src_uuid,
+					    &res.dst_uuid, res.offset,
+					    res.data_length, pkg->frame.size);
+		return false;
+	}
+
+	if (res.offset != prop_req.offset || !res.data_length ||
+	    res.data_length > TB_XDP_PROPERTIES_MAX_LENGTH) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop properties offset route=%llx req_seq=%u res_seq=%u req_offset=%u res_offset=%u data_len=%u frame_size=%u\n",
+					    tb_xdp_route(&prop_req.hdr),
+					    tb_xdp_sequence(&prop_req.hdr),
+					    tb_xdp_sequence(&res.hdr),
+					    prop_req.offset, res.offset,
+					    res.data_length, pkg->frame.size);
+		return false;
+	}
+
+	return true;
+}
+
+static bool tb_xdomain_match_common(const struct tb_cfg_request *req,
+				    const struct ctl_pkg *pkg)
+{
+	const struct tb_xdomain_protocol_header *res_hdr = pkg->buffer;
+	const struct tb_xdomain_protocol_header *req_hdr = req->request;
+
+	if (tb_xdomain_sequence(&res_hdr->xd_hdr) !=
+	    tb_xdomain_sequence(&req_hdr->xd_hdr)) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop seq req_uuid=%pUb res_uuid=%pUb route=%llx req_seq=%u res_seq=%u frame_size=%u\n",
+					    &req_hdr->uuid, &res_hdr->uuid,
+					    tb_xdomain_route(&req_hdr->xd_hdr),
+					    tb_xdomain_sequence(&req_hdr->xd_hdr),
+					    tb_xdomain_sequence(&res_hdr->xd_hdr),
+					    pkg->frame.size);
+		return false;
+	}
+
+	if ((res_hdr->xd_hdr.route_hi & ~BIT(31)) !=
+	    req_hdr->xd_hdr.route_hi) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop route_hi req_uuid=%pUb res_uuid=%pUb req_route=%llx res_route=%llx req_seq=%u res_seq=%u frame_size=%u\n",
+					    &req_hdr->uuid, &res_hdr->uuid,
+					    tb_xdomain_route(&req_hdr->xd_hdr),
+					    tb_xdomain_route(&res_hdr->xd_hdr),
+					    tb_xdomain_sequence(&req_hdr->xd_hdr),
+					    tb_xdomain_sequence(&res_hdr->xd_hdr),
+					    pkg->frame.size);
+		return false;
+	}
+
+	if (res_hdr->xd_hdr.route_lo != req_hdr->xd_hdr.route_lo) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop route_lo req_uuid=%pUb res_uuid=%pUb req_route=%llx res_route=%llx req_seq=%u res_seq=%u frame_size=%u\n",
+					    &req_hdr->uuid, &res_hdr->uuid,
+					    tb_xdomain_route(&req_hdr->xd_hdr),
+					    tb_xdomain_route(&res_hdr->xd_hdr),
+					    tb_xdomain_sequence(&req_hdr->xd_hdr),
+					    tb_xdomain_sequence(&res_hdr->xd_hdr),
+					    pkg->frame.size);
+		return false;
+	}
+
+	if (!uuid_equal(&res_hdr->uuid, &req_hdr->uuid)) {
+		if (xdomain_debug)
+			pr_info_ratelimited("thunderbolt xdomain: match drop protocol uuid req_uuid=%pUb res_uuid=%pUb route=%llx frame_size=%u\n",
+					    &req_hdr->uuid, &res_hdr->uuid,
+					    tb_xdomain_route(&req_hdr->xd_hdr),
+					    pkg->frame.size);
+		return false;
+	}
+
+	return true;
+}
+
+static void *tb_xdomain_bridge_pad_copy(const void *src, size_t src_size,
+					size_t *dst_size)
+{
+	const struct tb_xdp_header *src_hdr = src;
+	struct tb_xdp_header *dst_hdr;
+	u32 src_dwords = src_size / 4;
+	u32 pad_dwords, dst_dwords;
+	u32 src_pos, dst_pos, n;
+	u32 length;
+	u32 *w;
+	u8 *dst;
+
+	*dst_size = src_size;
+	if (!xdomain_bridge_pad || src_size % 4 ||
+	    src_dwords <= XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS)
+		return NULL;
+
+	pad_dwords = tb_xdomain_bridge_pad_dwords(src_dwords);
+	dst_dwords = src_dwords + pad_dwords;
+	if (dst_dwords * 4 > TB_FRAME_SIZE - 4)
+		return ERR_PTR(-EMSGSIZE);
+
+	length = src_hdr->xd_hdr.length_sn & TB_XDOMAIN_LENGTH_MASK;
+	if (length + pad_dwords > TB_XDOMAIN_LENGTH_MASK)
+		return ERR_PTR(-EMSGSIZE);
+
+	dst = kmalloc(dst_dwords * 4, GFP_KERNEL);
+	if (!dst)
+		return ERR_PTR(-ENOMEM);
+
+	w = (u32 *)dst;
+	memcpy(w, src, XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS * 4);
+
+	dst_hdr = (struct tb_xdp_header *)dst;
+	tb_xdomain_set_length(dst_hdr, length + pad_dwords);
+
+	src_pos = XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS;
+	dst_pos = XDOMAIN_BRIDGE_PAD_OFFSET_DWORDS;
+	while (src_pos < src_dwords) {
+		w[dst_pos] = src_hdr->xd_hdr.route_hi & ~BIT(31);
+		w[dst_pos + 1] = src_hdr->xd_hdr.route_lo;
+		w[dst_pos + 2] = dst_hdr->xd_hdr.length_sn;
+		w[dst_pos + 3] = ~0U;
+		dst_pos += XDOMAIN_BRIDGE_PAD_DWORDS;
+
+		n = min_t(u32, XDOMAIN_BRIDGE_DATA_DWORDS,
+			  src_dwords - src_pos);
+		memcpy(w + dst_pos, (const u32 *)src + src_pos, n * 4);
+		src_pos += n;
+		dst_pos += n;
+	}
+
+	*dst_size = dst_dwords * 4;
+	return dst;
+}
+
+static u16 tb_xdomain_bridge_properties_max_data_length(void)
+{
+	u32 max_frame_dwords = (TB_FRAME_SIZE - 4) / 4;
+	u32 max_data = TB_XDP_PROPERTIES_MAX_DATA_LENGTH;
+	u32 fixed_dwords, dwords;
+
+	if (!xdomain_bridge_pad)
+		return max_data;
+
+	if (xdomain_bridge_properties_chunk)
+		max_data = min_t(u32, max_data,
+				 xdomain_bridge_properties_chunk);
+
+	fixed_dwords = sizeof(struct tb_xdp_properties_response) / 4;
+	for (dwords = max_frame_dwords; dwords > fixed_dwords; dwords--) {
+		if (dwords + tb_xdomain_bridge_pad_dwords(dwords) <=
+		    max_frame_dwords)
+			return min_t(u32, max_data, dwords - fixed_dwords);
+	}
+
+	return 0;
+}
+
+static unsigned int tb_xdomain_properties_timeout(void)
+{
+	return xdomain_bridge_pad ? XDOMAIN_BRIDGE_PROPERTIES_TIMEOUT :
+				    XDOMAIN_DEFAULT_TIMEOUT;
+}
